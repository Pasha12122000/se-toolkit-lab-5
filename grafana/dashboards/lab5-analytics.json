          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN score BETWEEN 0 AND 25 THEN '0-25'\n    WHEN score BETWEEN 26 AND 50 THEN '26-50'\n    WHEN score BETWEEN 51 AND 75 THEN '51-75'\n    ELSE '76-100'\n  END AS bucket,\n  COUNT(*) AS count\nFROM interacts\nWHERE score IS NOT NULL\nGROUP BY bucket\nORDER BY bucket;",
          "refId": "A"
        }
      ],
      "title": "Score distribution",
      "type": "barchart"
    },
